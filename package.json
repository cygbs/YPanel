{
  "name": "ypanel",
  "version": "1.3.11",
  "description": "YPanel - Web Minecraft server manager",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "build:client": "vite build",
    "build:hub": "esbuild src/hub.ts --bundle --platform=node --outfile=dist/index.js --minify",
    "build:node": "esbuild src/node.ts --bundle --platform=node --outfile=dist-node/index.js --external:zigpty --minify",
    "build": "npm run typecheck && npm run build:client && npm run build:hub && npm run build:node && node scripts/copy-dist.js",
    "start": "vite build && tsx src/hub.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "js-yaml": "^5.2.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "ws": "^8.16.0",
    "zigpty": "^0.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
