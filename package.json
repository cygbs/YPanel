{
  "name": "ypanel",
  "version": "1.0.0",
  "description": "YPanel - Web Minecraft server manager",
  "private": true,
  "scripts": {
    "build:client": "vite build",
    "build:hub": "esbuild src/hub.ts --bundle --platform=node --outfile=dist/index.js --minify",
    "build:node": "esbuild src/node.ts --bundle --platform=node --outfile=dist-node/index.js --external:zigpty --minify",
    "build": "npm run build:client && npm run build:hub && npm run build:node && node scripts/copy-dist.js",
    "start": "vite build && tsx src/hub.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "vue": "^3.5.39",
    "ws": "^8.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zigpty": "^0.2.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^8.1.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
