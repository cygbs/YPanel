{
  "name": "ypanel",
  "version": "1.0.0",
  "description": "YPanel - Web Minecraft server manager",
  "private": true,
  "scripts": {
    "build:client": "esbuild src/client.ts --bundle --outfile=public/client.js --alias:vue=./node_modules/vue/dist/vue.esm-browser.prod.js --minify --define:process.env.NODE_ENV=\"\\\"production\\\"\"",
    "build:client:dev": "esbuild src/client.ts --bundle --outfile=public/client.js --alias:vue=./node_modules/vue/dist/vue.esm-browser.js",
    "build:hub": "esbuild src/hub.ts --bundle --platform=node --outfile=dist/index.js --minify",
    "build:node": "esbuild src/node.ts --bundle --platform=node --outfile=dist-node/index.js --external:node-pty --minify",
    "build": "npm run build:client && npm run build:hub && npm run build:node && node scripts/copy-dist.js",
    "start": "npm run build:client:dev && tsx src/hub.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "node-pty": "^1.0.0",
    "vue": "^3.5.39",
    "ws": "^8.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "node-pty@1.1.0": true
  }
}
