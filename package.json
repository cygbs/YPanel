{
  "name": "ypanel",
  "version": "1.4.3",
  "description": "YPanel — Web Minecraft server manager. Simple, fast, and friendly.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/cygbs/YPanel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cygbs/YPanel.git"
  },
  "keywords": [
    "minecraft",
    "server",
    "manager",
    "panel",
    "game-server"
  ],
  "bin": {
    "ypanel": "bin/ypanel.js"
  },
  "files": [
    "bin/",
    "dist/",
    "dist-node/",
    "README.md",
    "README_EN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:client": "vite build",
    "build:hub": "esbuild src/hub.ts --bundle --platform=node --outfile=dist/index.js --minify",
    "build:node": "esbuild src/node.ts --bundle --platform=node --outfile=dist-node/index.js --external:zigpty --minify",
    "build": "npm run typecheck && npm run build:client && npm run build:hub && npm run build:node && node scripts/copy-dist.js",
    "start": "vite build && tsx src/hub.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "element-plus": "^2.14.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "js-yaml": "^5.2.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "ws": "^8.16.0",
    "zigpty": "^0.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^7.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
